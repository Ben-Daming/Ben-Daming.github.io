---
import PostMeta from './PostMeta.astro';
import type { BlogPost } from '../lib/blog';
import { getExcerpt, getPostUrl } from '../lib/blog';

interface Props {
  post: BlogPost;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
---
<article class:list={["post-card", { featured }]}>
  <PostMeta post={post} />
  <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
  <p>{getExcerpt(post, featured ? 190 : 132)}</p>
  <a class="read-more" href={getPostUrl(post)} aria-label={`阅读全文：${post.data.title}`}>阅读全文</a>
</article>
