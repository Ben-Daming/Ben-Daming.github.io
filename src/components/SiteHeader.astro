---
import { siteConfig } from '../site.config';

const path = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header">
  <a class="skip-link" href="#main-content">跳到正文</a>
  <div class="header-card">
    <a class="brand" href="/" aria-label="返回首页">
      <img src={siteConfig.avatar} alt="Ben Daming avatar" class="brand-avatar" />
      <span>
        <span class="brand-kicker">Undergraduate Notes</span>
        <span class="brand-name">{siteConfig.name}</span>
      </span>
    </a>
    <nav class="site-nav" aria-label="主导航">
      {siteConfig.nav.map((item) => (
        <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
