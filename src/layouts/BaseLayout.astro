---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../site.config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = siteConfig.description, bodyClass = '' } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const canonical = new URL(Astro.url.pathname, siteConfig.url).toString();
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/images/avatar.png" />
    <link rel="alternate" type="application/rss+xml" title={siteConfig.title} href="/feed.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body class={bodyClass}>
    <div class="site-shell">
      <SiteHeader />
      <main id="main-content" class="site-main">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
