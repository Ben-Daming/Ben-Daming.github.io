---
import { getCollection, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';
import { getAdjacentPosts, getPostSlug, sortPosts } from '../lib/blog';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog', ({ data }) => !data.draft));
  return posts.map((post) => {
    const { older, newer } = getAdjacentPosts(posts, post);
    return {
      params: { slug: getPostSlug(post) },
      props: { post, older, newer }
    };
  });
}

const { post, older, newer } = Astro.props;
const { Content, headings } = await render(post);
---
<PostLayout post={post} headings={headings} older={older} newer={newer}>
  <Content />
</PostLayout>
