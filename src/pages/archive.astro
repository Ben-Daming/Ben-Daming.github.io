---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, getPostUrl, sortPosts } from '../lib/blog';

const posts = sortPosts(await getCollection('blog', ({ data }) => !data.draft));
const groups = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const year = String(post.data.date.getFullYear());
  acc[year] = acc[year] ?? [];
  acc[year].push(post);
  return acc;
}, {});
---
<BaseLayout title="归档" description="按年份浏览所有文章。">
  <section class="page-hero compact">
    <p class="eyebrow">Archive</p>
    <h1>归档</h1>
    <p>按时间回看写作轨迹。</p>
  </section>

  <div class="archive-list">
    {Object.entries(groups).map(([year, entries]) => (
      <section class="archive-year" aria-labelledby={`year-${year}`}>
        <h2 id={`year-${year}`}>{year}</h2>
        <ul>
          {entries.map((post) => (
            <li>
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <a href={getPostUrl(post)}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
